<ul role="list" class="px-4 divide-y divide-gray-100">
  <% @contest_seasons.each do |contest_season| %>
    <li class="flex items-center justify-between gap-x-6 py-5">
      <div class="min-w-0">
        <div class="flex items-start gap-x-3">
          <p class="font-semibold text-gray-900"><%= contest_season.name %></p>
        </div>
        <div class="mt-1 gap-x-2 text-xs/5 text-gray-500">
          <%= pluralize(contest_season.contests.count, 'contest') %>
        </div>
      </div>
      <div class="flex flex-none items-center gap-x-4">
        <%= link_to "View", contest_season, class: "btn-primary-sm" %>
      </div>
    </li>
  <% end %>
</ul>

<div class="p-3 border-t">
  <%== pagy_nav(@pagy) %>
</div>
