<% content_for :title, "3D Button Design System" %>

<div class="max-w-4xl mx-auto p-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">3D Button Design System</h1>
    <p class="text-gray-600 mb-4">
      Testing Josh Comeau's 3D button design implementation with our semantic button classes.
      This page demonstrates the full 3D effect on <code>&lt;button&gt;</code> elements vs limited effect on <code>&lt;input&gt;</code> elements.
    </p>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
      <h3 class="font-semibold text-yellow-800 mb-2">Testing Instructions:</h3>
      <ul class="text-yellow-700 text-sm space-y-1">
        <li>• Hover over buttons to see the lift animation</li>
        <li>• Click and hold to see the press animation</li>
        <li>• Compare button vs input element behaviors</li>
        <li>• Test keyboard navigation with Tab and Enter/Space</li>
      </ul>
    </div>
  </div>

  <!-- Primary Buttons -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Primary Buttons (State-changing actions)</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Regular Size</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element (full 3D effect):</label>
            <button type="button" class="btn-primary">Save Changes</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Input submit (limited effect):</label>
            <input type="submit" value="Submit Form" class="btn-primary">
          </div>
        </div>
      </div>
      
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Small Size (-sm)</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element:</label>
            <button type="button" class="btn-primary-sm">Save</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Input submit:</label>
            <input type="submit" value="Submit" class="btn-primary-sm">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondary Buttons -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Secondary Buttons (Non-state actions)</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Regular Size</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element:</label>
            <button type="button" class="btn-secondary">Cancel</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Link styled as button:</label>
            <%= link_to "Back to List", "#", class: "btn-secondary" %>
          </div>
        </div>
      </div>
      
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Small Size (-sm)</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element:</label>
            <button type="button" class="btn-secondary-sm">Cancel</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Link styled as button:</label>
            <%= link_to "Back", "#", class: "btn-secondary-sm" %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Danger Buttons -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Danger Buttons (Destructive actions)</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Regular Size</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element:</label>
            <button type="button" class="btn-danger">Delete Contest</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Form with method delete:</label>
            <%= form_with url: "#", method: :delete, local: true, class: "inline" do |form| %>
              <%= form.submit "Delete Entry", class: "btn-danger" %>
            <% end %>
          </div>
        </div>
      </div>
      
      <div>
        <h3 class="text-lg font-medium text-gray-700 mb-4">Small Size (-sm)</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-600 mb-2">Button element:</label>
            <button type="button" class="btn-danger-sm">Delete</button>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2">Form with method delete:</label>
            <%= form_with url: "#", method: :delete, local: true, class: "inline" do |form| %>
              <%= form.submit "Delete", class: "btn-danger-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- Button Groups -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Real-world Button Groups</h2>
    <p class="text-gray-600 mb-4">How buttons look in typical form contexts:</p>
    
    <div class="bg-gray-50 rounded-lg p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Contest Entry Form Actions</h3>
      <div class="flex flex-wrap gap-3">
        <button type="button" class="btn-primary">Save Entry</button>
        <button type="button" class="btn-secondary">Save as Draft</button>
        <button type="button" class="btn-secondary">Cancel</button>
      </div>
      
      <h3 class="text-lg font-medium text-gray-900 mb-4 mt-8">Music Management Actions</h3>
      <div class="flex flex-wrap gap-3">
        <button type="button" class="btn-primary-sm">Add Music</button>
        <button type="button" class="btn-secondary-sm">Preview</button>
        <button type="button" class="btn-danger-sm">Remove</button>
      </div>
    </div>
  </section>

  <!-- Technical Notes -->
  <section class="mb-8">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Technical Implementation Notes</h2>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="font-semibold text-blue-800 mb-3">Key Implementation Details:</h3>
      <ul class="text-blue-700 space-y-2">
        <li><strong>Clean 3D shadow:</strong> Using <code>::before</code> pseudo-element for shadow layer only</li>
        <li><strong>Solid colors:</strong> No gradients or transparency - buttons maintain flat, vibrant colors</li>
        <li><strong>Animation timing:</strong> 600ms default, 250ms hover, 34ms active with cubic-bezier curves</li>
        <li><strong>Transform scaling:</strong> Regular buttons: -4px/-6px/-2px, Small buttons: -3px/-4px/-1px</li>
        <li><strong>Input limitations:</strong> <code>&lt;input&gt;</code> elements can't use pseudo-elements, so they get simplified styling</li>
        <li><strong>Accessibility:</strong> All animations respect <code>prefers-reduced-motion</code></li>
      </ul>
    </div>
  </section>

  <!-- Navigation -->
  <div class="border-t pt-6">
    <%= link_to "← Back to Application", root_path, class: "btn-secondary" %>
  </div>
</div>