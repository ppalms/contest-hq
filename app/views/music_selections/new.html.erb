<% content_for :title, "Add Custom Music" %>

<div class="pt-8 max-w-2xl mx-auto" data-controller="focus-manager">
  <a href="#custom_music_form" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-blue-600 text-white px-3 py-2 rounded">
    Skip to music form
  </a>
  <h1 class="text-2xl font-bold mb-6">Add Custom Music</h1>

  <%= form_with model: @music_selection, url: contest_entry_music_selections_path(contest_id: @contest_entry.contest_id, entry_id: @contest_entry.id), method: :post, 
                data: { controller: "form-focus" },
                id: "custom_music_form",
                role: "form",
                "aria-label": "Add custom music selection" do |f| %>
    <% if @music_selection.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded p-4 mb-6">
        <h3 class="font-bold text-red-800 mb-2">Errors:</h3>
        <ul class="list-disc list-inside text-red-700">
          <% @music_selection.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-4">
      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, 
            class: "text-field w-full", 
            required: true,
            data: { form_focus_target: "field" },
            "aria-describedby": "title_help" %>
        <p id="title_help" class="text-xs text-gray-500 mt-1">
          Enter the full title of the musical piece.
        </p>
      </div>

      <div>
        <%= f.label :composer, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :composer, 
            class: "text-field w-full", 
            required: true,
            data: { form_focus_target: "field" },
            "aria-describedby": "composer_help" %>
        <p id="composer_help" class="text-xs text-gray-500 mt-1">
          Enter the composer's name (Last, First or First Last format).
        </p>
      </div>

      <%= f.hidden_field :position, value: params[:position] %>
    </div>

    <div class="flex justify-end gap-3 mt-6">
      <%= link_to "Cancel", 
          contest_entry_path(@contest_entry.contest, @contest_entry), 
          class: "btn-secondary",
          data: { form_focus_target: "cancel" } %>
      <%= f.submit "Add Music Selection", 
          class: "btn-primary",
          data: { form_focus_target: "submit" } %>
    </div>
  <% end %>
</div>
